                          "width": 120,
                          "content": "Day 4",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "bAU1F",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Migration architecture generated from lineage topology. Azure Data Factory pipeline structure produced. Sequencing derived from dependency order. Strategic handoff documentation delivered.",
                          "lineHeight": 1.65,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
