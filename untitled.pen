                      "children": [
                        {
                          "type": "text",
                          "id": "MbJw4",
                          "fill": "#ffffffff",
                          "content": "Thinking beats reacting.",
                          "lineHeight": 1.3,
                          "fontFamily": "Newsreader",
                          "fontSize": 20,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "1hkB5",
                          "fill": "#d1d1d1ff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Reactive organizations mistake activity for progress. Structured thinking creates the conditions for decisions that hold under pressure.",
