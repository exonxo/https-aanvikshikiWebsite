                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Thinking differently about a complex problem?",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
