              "content": "HOW WE THINK",
              "fontFamily": "Funnel Sans",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "O0DCN",
              "name": "hH1",
              "fill": "#1A1A1A",
              "content": "How We Think.",
              "fontFamily": "Newsreader",
              "fontSize": 48,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "Qn2SH",
              "name": "hSub",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Where most thinking stops, we begin. Four disciplines that separate structured reasoning from reactive decision-making.",
              "lineHeight": 1.6,
              "fontFamily": "Geist",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
