                  "gap": 16,
                  "children": [
                    {
                      "type": "frame",
                      "id": "mfy2C",
                      "name": "st2Conv",
                      "width": "fill_container",
                      "fill": "#F7F8FA",
                      "stroke": {
                        "thickness": 1,
                        "fill": "#F3F4F6"
                      },
                      "layout": "vertical",
                      "gap": 10,
                      "padding": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "E1TKn",
                          "fill": "#888888",
                          "content": "MOST ORGANIZATIONS",
                          "fontFamily": "Funnel Sans",
                          "fontSize": 11,
                          "fontWeight": "normal",
                          "letterSpacing": 1.5
                        },
                        {
                          "type": "text",
                          "id": "b9rYz",
                          "fill": "#1A1A1A",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Define the problem as stated, then work to solve it.",
                          "lineHeight": 1.6,
                          "fontFamily": "Geist",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
