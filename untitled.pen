                },
                {
                  "type": "text",
                  "id": "QVfFv",
                  "name": "csCat",
                  "fill": "#FF5C00",
                  "content": "AI Strategy — Healthcare",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 1
                }
              ]
            },
            {
              "type": "text",
              "id": "T1CIC",
              "name": "csTitle",
              "fill": "#1A1A1A",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Strategic Clarity Before Migration: How an Organization Learned What It Had Before Deciding Where to Go",
              "lineHeight": 1.25,
              "fontFamily": "Newsreader",
              "fontSize": 22,
              "fontWeight": "600"
            },
            {
              "type": "frame",
              "id": "sYfR6",
              "name": "csImg",
              "metadata": {
                "type": "unsplash",
                "username": "dashxatami",
