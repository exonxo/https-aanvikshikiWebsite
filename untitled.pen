                    "thickness": 1,
                    "fill": "#E2E8F0"
                  }
                }
              ]
            },
            {
              "type": "frame",
              "id": "4Bmcx",
              "name": "observeSec",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "XqXR5",
                  "fill": "#94A3B8",
                  "content": "Observe",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 1.5
                },
                {
                  "type": "frame",
                  "id": "vc2YB",
                  "name": "obsInner",
                  "width": "fill_container",
                  "gap": 40,
                  "children": [
                    {
                      "type": "frame",
                      "id": "KjZT4",
                      "name": "obsLeft",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "1AGXH",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "A regional healthcare provider needed to migrate its data infrastructure. The mandate was clear. The path was not. Eleven years of incremental system-building had produced 259 SSIS packages spanning 12 source systems — none of them documented, many of them interdependent in ways no one fully understood.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "DcsA7",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Power BI reports had been built by multiple teams over time, with dependencies tracing back to staging tables that were themselves undocumented. Before any strategic decision could be made about where to go, the organization needed to understand where it was. Manual analysis was estimated at 6–8 weeks — before migration planning could even begin.",
                          "lineHeight": 1.7,
                          "fontFamily": "Inter",
                          "fontSize": 15,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "vEHQn",
                      "name": "obsRight",
                      "width": "fill_container",
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "frame",
                          "id": "WXVBw",
                          "name": "fr1",
                          "width": "fill_container",
                          "stroke": {
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "#E2E8F0"
                          },
                          "padding": [
                            8,
                            0
                          ],
                          "justifyContent": "space_between",
                          "children": [
                            {
                              "type": "text",
                              "id": "RWXU8",
                              "fill": "#64748B",
                              "content": "The challenge",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "QM61y",
                              "fill": "#0f172a",
                              "content": "Migrate without a map",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "9onM5",
                          "name": "fr2",
                          "width": "fill_container",
                          "stroke": {
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "#E2E8F0"
                          },
                          "padding": [
