          "children": [
            {
              "type": "text",
              "id": "Zhujr",
              "name": "anaLbl",
              "fill": "#FF5C00",
              "content": "Analyze → Synthesize",
              "fontFamily": "Funnel Sans",
              "fontSize": 11,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "BY6QW",
              "name": "anaP1",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "An AI agent was deployed against the full package catalog and Power BI metadata store. Rather than documenting the system manually, the agent constructed a directed dependency graph — each package a node, each data relationship an edge.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "NsElG",
              "name": "anaP2",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Column-level lineage was traced from report visuals back to source tables. By the end of Day 4, the organization had a complete strategic picture of its data estate — the first time that had ever been true.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 14,
              "fontWeight": "normal"
            },
