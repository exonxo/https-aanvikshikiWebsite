                          "fill": "#ffffffff",
                          "textGrowth": "fixed-width",
                          "width": 400,
                          "content": "Clarity beats speed.",
                          "lineHeight": 1.3,
                          "fontFamily": "Newsreader",
                          "fontSize": 20,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
