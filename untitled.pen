                          "width": 120,
                          "content": "Day 3",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "fFVot",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Power BI report metadata cross-referenced against the lineage graph. 94 reports traced to 612 upstream sources. Column-level lineage generated — executives can now see what breaks if any component changes.",
                          "lineHeight": 1.65,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
