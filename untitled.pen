                      "name": "f1l",
                      "fill": "#FF5C00",
                      "content": "The challenge",
                      "fontFamily": "Funnel Sans",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
