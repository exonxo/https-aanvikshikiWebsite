                "thickness": 1,
                "fill": "#E2E8F0"
              }
            }
          ]
        },
        {
          "type": "frame",
          "id": "CIszE",
          "name": "etym",
          "width": "fill_container",
          "height": 689,
          "fill": "#ffffffff",
          "stroke": {
            "thickness": {
              "bottom": 1
            },
            "fill": "#E2E8F0"
          },
          "layout": "vertical",
          "gap": 20,
          "padding": [
            80,
            60
          ],
          "justifyContent": "center",
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "mu9bi",
              "fill": "#0f62feff",
              "content": "THE NAME",
              "fontFamily": "IBM Plex Mono",
              "fontSize": 12,
              "fontWeight": "normal",
              "letterSpacing": 2
            },
            {
              "type": "text",
              "id": "IM9Pq",
              "fill": "#0f172a",
              "textGrowth": "fixed-width",
              "width": 680,
              "content": "Ancient Wisdom. Modern Execution.",
              "lineHeight": 1.25,
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "5dSL1",
              "fill": "#64748B",
              "textGrowth": "fixed-width",
              "width": 680,
              "content": "Ānvīkṣikī appears in the Arthashastra — Kautilya's treatise on statecraft — as one of the four sciences a leader must master. It is defined as the lamp of all learning, the means of all action, and the foundation of all knowledge.",
              "lineHeight": 1.7,
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "vf7lU",
              "fill": "#64748B",
              "textGrowth": "fixed-width",
              "width": 680,
              "content": "We took the name because it captures what we believe is missing in most AI-enabled organizations: not more data, not more models, but a rigorous discipline of inquiry that precedes any of it. The ancient idea is that structured thinking is not a soft skill — it is a strategic capability. That belief is the foundation of everything we do.",
              "lineHeight": 1.7,
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            }
          ]
        },
        {
