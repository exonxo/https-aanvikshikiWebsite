              "width": 360,
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "XDzdc",
                  "fill": "#888888",
                  "content": "02",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "ML8B3",
                  "fill": "#1A1A1A",
                  "content": "Analyze",
                  "fontFamily": "Newsreader",
                  "fontSize": 30,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "pbBo1",
                  "fill": "#666666",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Break down complexity into structured insights. Most complex problems are not single problems — they are clusters of interdependent conditions. We map these dependencies before we name the challenge, because the wrong diagnosis produces the wrong response.",
                  "lineHeight": 1.7,
                  "fontFamily": "Geist",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "gDpYC",
                  "fill": "#888888",
                  "content": "IN PRACTICE",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 1.5
                },
                {
                  "type": "text",
                  "id": "jRqOI",
                  "fill": "#666666",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Root cause analysis, dependency mapping, scenario modeling, and structured decomposition of the problem space into addressable components.",
                  "lineHeight": 1.65,
                  "fontFamily": "Geist",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "nQX9m",
              "name": "st2R",
              "width": "fill_container",
              "height": "fill_container",
              "layout": "vertical",
              "gap": 20,
              "justifyContent": "space_between",
              "children": [
                {
                  "type": "frame",
                  "id": "7xL7j",
