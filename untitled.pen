                      "fill": "#0f172a",
                      "textGrowth": "fixed-width",
                      "width": 400,
                      "content": "Clarity beats speed.",
                      "lineHeight": 1.3,
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "yFXom",
                      "fill": "#64748B",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Most organizations move fast in the wrong direction. We slow the thinking down before the execution speeds up.",
