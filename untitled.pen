            {
              "type": "frame",
              "id": "hAVLO",
              "name": "anaSec",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "LgzPm",
                  "fill": "#ff5c00ff",
                  "content": "Analyze → Synthesize",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 1.5
                },
                {
                  "type": "text",
                  "id": "RNsJk",
                  "fill": "#666666",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "An AI agent was deployed against the full package catalog and Power BI metadata store. Rather than documenting the system manually, the agent constructed a directed dependency graph — each package a node, each data relationship an edge. What had been invisible became structural. What had been assumed became verifiable.",
                  "lineHeight": 1.7,
                  "fontFamily": "Geist",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "962Kn",
                  "fill": "#666666",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Column-level lineage was traced from report visuals back to source tables. Business logic embedded in transformation expressions was extracted and annotated. By the end of Day 4, the organization had a complete strategic picture of its data estate — the first time that had ever been true.",
                  "lineHeight": 1.7,
                  "fontFamily": "Geist",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
