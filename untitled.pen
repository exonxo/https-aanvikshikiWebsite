              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "6qGSY",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "01 — Every engagement begins with questions, not proposals.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "7qHFd",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "02 — Complexity is not simplified — it is structured.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "yY0zR",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "03 — We distinguish between the stated problem and the actual problem.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "9GWWG",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "04 — Speed of execution follows clarity of thinking.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "CzY4t",
                  "fill": "#1A1A1A",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "05 — Ethics is embedded at synthesis, not added at the end.",
                  "lineHeight": 1.6,
                  "fontFamily": "Geist",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "Vqbqj",
          "name": "Step 1 - Observe",
          "width": "fill_container",
          "height": 440,
          "fill": "#FFFFFF",
