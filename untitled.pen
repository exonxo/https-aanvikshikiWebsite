          "gap": 32,
          "padding": 60,
          "children": [
            {
              "type": "text",
              "id": "Dbmiw",
              "fill": "#888888",
              "content": "GOVERNING PRINCIPLES",
              "fontFamily": "Funnel Sans",
              "fontSize": 11,
