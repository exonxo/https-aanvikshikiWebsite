                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Strategic Clarity Before Migration: How an Organization Learned What It Had Before Deciding Where to Go",
                      "lineHeight": 1.25,
                      "fontFamily": "Newsreader",
                      "fontSize": 24,
                      "fontWeight": "600"
                    }
                  ]
                },
