                          "content": "Day 1",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "Wcsyv",
                          "fill": "#64748B",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "AI agent deployed against the full SSIS package catalog. Dependency graph seeded from 259 packages. Initial structure of the data estate becomes visible for the first time.",
                          "lineHeight": 1.65,
                          "fontFamily": "Inter",
