        },
        {
          "type": "frame",
          "id": "qPPcv",
          "name": "mObserve",
          "width": "fill_container",
          "stroke": {
            "thickness": {
              "bottom": 1
            },
            "fill": "#F3F4F6"
          },
          "layout": "vertical",
          "gap": 24,
          "padding": [
            48,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "PsVBI",
              "name": "obsLbl",
              "fill": "#FF5C00",
              "content": "Observe",
              "fontFamily": "Funnel Sans",
              "fontSize": 11,
              "fontWeight": "normal",
              "letterSpacing": 1.5
            },
            {
              "type": "text",
              "id": "Z1G0h",
              "name": "obsP1",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A regional healthcare provider needed to migrate its data infrastructure. The mandate was clear. The path was not. Eleven years of incremental system-building had produced 259 SSIS packages spanning 12 source systems — none of them documented.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "Cwwgd",
              "name": "obsP2",
              "fill": "#666666",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Power BI reports had been built by multiple teams over time, with dependencies tracing back to staging tables that were themselves undocumented. Manual analysis was estimated at 6–8 weeks.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 14,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "CAbOA",
              "name": "mFacts",
              "width": "fill_container",
              "layout": "vertical",
              "children": [
                {
                  "type": "frame",
                  "id": "8792Q",
                  "name": "f1",
                  "width": "fill_container",
                  "stroke": {
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#F3F4F6"
                  },
                  "layout": "vertical",
