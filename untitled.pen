                  "name": "st1Num",
                  "fill": "#FF5C00",
                  "content": "01 — Observe",
                  "fontFamily": "Funnel Sans",
                  "fontSize": 11,
                  "fontWeight": "500",
                  "letterSpacing": 1.5
                },
                {
                  "type": "text",
                  "id": "xlmY8",
                  "name": "st1T",
                  "fill": "#1A1A1A",
                  "content": "See what's actually there.",
                  "fontFamily": "Newsreader",
                  "fontSize": 28,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "g1qbN",
                  "name": "st1D",
                  "fill": "#666666",
                  "textGrowth": "fixed-width",
                  "width": 357,
                  "content": "Before forming any hypothesis, we map the actual landscape. Primary sources, not secondary summaries. Data patterns, not anecdotal examples. We observe without agenda.",
                  "lineHeight": 1.7,
                  "fontFamily": "Geist",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "jXR27",
                  "name": "st1IP",
                  "fill": "#888888",
                  "textGrowth": "fixed-width",
                  "width": 357,
                  "content": "In practice: Stakeholder interviews, data audits, system mapping, process observation",
                  "lineHeight": 1.5,
                  "fontFamily": "Funnel Sans",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "w3Vev",
              "name": "st1R",
              "width": "fill_container",
              "height": "fill_container",
