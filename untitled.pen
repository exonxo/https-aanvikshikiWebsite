                          "content": "01",
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "5HUVU",
                          "fill": "#94A3B8",
                          "content": "AI Strategy — Healthcare",
                          "fontFamily": "IBM Plex Mono",
                          "fontSize": 11,
                          "fontWeight": "normal",
                          "letterSpacing": 1
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "1s1fw",
                      "fill": "#0f172a",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Strategic Clarity Before Migration: How an Organization Learned What It Had Before Deciding Where to Go",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "600"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "JFpzI",
                  "name": "cs01img",
                  "metadata": {
                    "type": "unsplash",
                    "username": "hieu101193",
                    "link": "https://unsplash.com/@hieu101193",
                    "author": "Đào Hiếu"
                  },
                  "width": 520,
                  "height": 293,
                  "fill": {
                    "type": "image",
                    "enabled": true,
                    "url": "https://images.unsplash.com/photo-1759836096334-e65e1706bb59?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzQ3ODM1NzV8&ixlib=rb-4.1.0&q=80&w=1080",
