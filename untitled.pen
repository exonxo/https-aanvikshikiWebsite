                          "content": "Rely on assumption and selective evidence",
                          "lineHeight": 1.5,
                          "fontFamily": "Geist",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "1gpNO",
                      "name": "st1Anv",
                      "width": "fill_container",
                      "fill": "#1A1A1A",
                      "layout": "vertical",
                      "gap": 8,
                      "padding": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "2AcLU",
                          "name": "st1AnvLb",
                          "fill": "#FF5C00",
                          "content": "Aanvikshiki",
                          "fontFamily": "Funnel Sans",
                          "fontSize": 11,
                          "fontWeight": "500",
                          "letterSpacing": 1
                        },
                        {
                          "type": "text",
                          "id": "75qAM",
                          "fill": "#d1d5db",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Map the environment — stakeholders, systems, and the actual decisions being made — before naming the challenge.",
                          "lineHeight": 1.65,
                          "fontFamily": "Geist",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "SRaW1",
                  "name": "st1QF",
                  "width": "fill_container",
                  "gap": 14,
                  "children": [
                    {
                      "type": "frame",
                      "id": "LZ4dy",
                      "opacity": 0.4,
                      "width": 2,
                      "height": "fill_container",
                      "fill": "#FF5C00"
                    },
                    {
                      "type": "frame",
                      "id": "7Tfvp",
                      "name": "st1QC",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 8,
                      "children": [
                        {
                          "type": "text",
                          "id": "IggRo",
                          "fill": "#888888",
                          "content": "FROM THE FIELD",
                          "fontFamily": "Funnel Sans",
                          "fontSize": 11,
                          "fontWeight": "normal",
                          "letterSpacing": 1.5
                        },
                        {
                          "type": "text",
                          "id": "o4eJi",
                          "fill": "#334155",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "\"The stated problem was 'we need to migrate to Azure.' Through stakeholder interviews, we discovered the actual problem: no one could say what data was being transformed or why.\"",
                          "lineHeight": 1.7,
                          "fontFamily": "Geist",
                          "fontSize": 14,
                          "fontWeight": "normal",
                          "fontStyle": "italic"
                        },
                        {
                          "type": "text",
                          "id": "Cinug",
                          "fill": "#888888",
                          "content": "— SSIS Infrastructure Engagement, 2024",
                          "fontFamily": "Geist",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "jbivd",
          "name": "st2",
          "width": "fill_container",
          "fill": "#F7F8FA",
          "stroke": {
            "thickness": {
              "bottom": 1
            },
