                            0
                          ],
                          "justifyContent": "space_between",
                          "children": [
                            {
                              "type": "text",
                              "id": "iHhkR",
                              "fill": "#64748B",
                              "content": "Infrastructure scope",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "F71eX",
                              "fill": "#0f172a",
                              "content": "259 SSIS packages, 12 source systems",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "9Iw90",
                          "name": "fr3",
                          "width": "fill_container",
                          "stroke": {
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "#E2E8F0"
                          },
                          "padding": [
                            8,
                            0
                          ],
                          "justifyContent": "space_between",
                          "children": [
                            {
                              "type": "text",
                              "id": "oe2V1",
                              "fill": "#64748B",
                              "content": "Documentation",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "wY0Xz",
                              "fill": "#0f172a",
                              "content": "None — no lineage, no dependency graph",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "1yoZU",
                          "name": "fr4",
                          "width": "fill_container",
                          "stroke": {
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "#E2E8F0"
                          },
                          "padding": [
                            8,
                            0
                          ],
                          "justifyContent": "space_between",
                          "children": [
                            {
                              "type": "text",
                              "id": "0gYvy",
                              "fill": "#64748B",
                              "content": "BI layer",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "Fnvl8",
                              "fill": "#0f172a",
                              "content": "94 Power BI reports with unresolved dependencies",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "6yMXw",
                          "name": "fr5",
                          "width": "fill_container",
                          "padding": [
                            8,
                            0
                          ],
                          "justifyContent": "space_between",
                          "children": [
                            {
                              "type": "text",
                              "id": "VIVsL",
                              "fill": "#64748B",
                              "content": "Pre-migration estimate",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "USo4j",
                              "fill": "#0f172a",
                              "content": "6–8 weeks of manual analysis",
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "hAVLO",
              "name": "anaSec",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 24,
              "children": [
                {
                  "type": "text",
                  "id": "LgzPm",
                  "fill": "#94A3B8",
                  "content": "Analyze → Synthesize",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 11,
                  "fontWeight": "normal",
                  "letterSpacing": 1.5
                },
                {
                  "type": "text",
                  "id": "RNsJk",
                  "fill": "#64748B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "An AI agent was deployed against the full package catalog and Power BI metadata store. Rather than documenting the system manually, the agent constructed a directed dependency graph — each package a node, each data relationship an edge. What had been invisible became structural. What had been assumed became verifiable.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "962Kn",
                  "fill": "#64748B",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Column-level lineage was traced from report visuals back to source tables. Business logic embedded in transformation expressions was extracted and annotated. By the end of Day 4, the organization had a complete strategic picture of its data estate — the first time that had ever been true.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "bXkkD",
                  "name": "tlCont",
                  "width": "fill_container",
                  "stroke": {
                    "thickness": 1,
                    "fill": "#E2E8F0"
                  },
                  "layout": "vertical",
                  "children": [
                    {
