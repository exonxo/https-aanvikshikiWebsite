                          "type": "text",
                          "id": "XyzPT",
                          "fill": "#ffffffff",
                          "content": "Ethics beats short-term gains.",
                          "lineHeight": 1.3,
                          "fontFamily": "Newsreader",
                          "fontSize": 20,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "Du2Ic",
                          "fill": "#d1d1d1ff",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
